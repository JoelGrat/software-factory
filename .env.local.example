# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Provider — one of: claude | openai | mock
AI_PROVIDER=claude

# Claude (if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Internal API — shared secret for machine-to-machine endpoints (e.g. stale run reaper)
INTERNAL_API_SECRET=change-me-in-production
